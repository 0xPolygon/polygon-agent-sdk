# MiniMax API key for the payments agent's reasoning model (MiniMax-M2.7)
# Get one at https://platform.minimax.io
MINIMAX_API_KEY=

# Anthropic API key — only needed if you switch the agent's model back to Claude
ANTHROPIC_API_KEY=

# Optional: override the Sequence project access key.
# If unset, the agent inherits whatever the polygon-agent CLI has configured
# in ~/.polygon-agent/builder.json from the host machine's setup run.
SEQUENCE_PROJECT_ACCESS_KEY=

# Optional: shared-secret header check on the webhook endpoint.
# Production deployments should set this to a long random string and
# require the same value in an X-Webhook-Secret header on incoming requests.
WEBHOOK_SECRET=
