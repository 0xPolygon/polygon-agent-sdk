  },
  "dependencies": {
    "@flue/sdk": "^0.3.10",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@flue/cli": "^0.3.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
